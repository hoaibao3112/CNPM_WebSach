# Server Configuration
PORT=5000

# Client URLs
CLIENT_ADMIN_URL=http://localhost:3000
CLIENT_CUSTOMER_URL=https://cnpm-web-sach.vercel.app

NODE_ENV=development

# Database Configuration
DB_NAME=qlbs
DB_USER=root
DB_PASSWORD=YOUR_DB_PASSWORD_HERE
DB_HOST=127.0.0.1
DB_PORT=3306

# Email Configuration (Gmail SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=YOUR_APP_PASSWORD_HERE

# JWT Configuration
JWT_SECRET=YOUR_JWT_SECRET_HERE
JWT_EXPIRES_IN=4h
REFRESH_TOKEN_SECRET=YOUR_REFRESH_TOKEN_SECRET_HERE
REFRESH_TOKEN_EXPIRES_IN=14d

# VNPay Payment Configuration
VNP_TMNCODE=YOUR_VNP_TMNCODE
VNP_HASHSECRET=YOUR_VNP_HASH_SECRET_HERE
VNP_API_URL=https://sandbox.vnpayment.vn/merchant_webapi/api/transaction
VNP_RETURN_URL=https://your_domain.com/api/orders/vnpay_return
VNP_IPN_URL=https://your_domain.com/api/orders/vnpay_ipn
VNP_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html

# Google API Configuration
GENNIAMA_API_KEY=YOUR_GOOGLE_API_KEY_HERE

# Google OAuth Configuration
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET_HERE

# Facebook OAuth Configuration
FACEBOOK_CLIENT_ID=YOUR_FACEBOOK_APP_ID_HERE
FACEBOOK_CLIENT_SECRET=YOUR_FACEBOOK_APP_SECRET_HERE
FACEBOOK_CALLBACK_URL=https://your_domain.com/auth/facebook/callback

# MoMo Payment Configuration
MOMO_PARTNER_CODE=MOMO
MOMO_ACCESS_KEY=YOUR_MOMO_ACCESS_KEY_HERE
MOMO_SECRET_KEY=YOUR_MOMO_SECRET_KEY_HERE
MOMO_API_URL=https://test-payment.momo.vn/v2/gateway/api/create
MOMO_REDIRECT_URL=https://your_domain.com/api/payments/momo-return
MOMO_IPN_URL=https://your_domain.com/api/payments/momo-ipn

# ZaloPay Payment Configuration
ZALOPAY_APP_ID=2554
ZALOPAY_KEY1=YOUR_ZALOPAY_KEY1_HERE
ZALOPAY_KEY2=YOUR_ZALOPAY_KEY2_HERE
ZALOPAY_ENDPOINT=https://sb-openapi.zalopay.vn/v2/create
ZALOPAY_REDIRECT_URL=https://your_domain.com/payments/zalopay-return
ZALOPAY_IPN_URL=https://your_domain.com/payments/zalopay-ipn

# Logging
LOG_LEVEL=debug
