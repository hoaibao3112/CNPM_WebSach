# Server Configuration
PORT=5000

# Client URLs
CLIENT_ADMIN_URL=http://localhost:3000
CLIENT_CUSTOMER_URL=http://localhost:5501

NODE_ENV=development

# Database Configuration
DB_NAME=qlbs
DB_USER=root
DB_PASSWORD=YOUR_DB_PASSWORD_HERE
DB_HOST=127.0.0.1
DB_PORT=3306

# Email Configuration (Gmail SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=YOUR_APP_PASSWORD_HERE

# JWT Configuration
JWT_SECRET=YOUR_JWT_SECRET_HERE
JWT_EXPIRES_IN=4h
REFRESH_TOKEN_SECRET=YOUR_REFRESH_TOKEN_SECRET_HERE
REFRESH_TOKEN_EXPIRES_IN=14d

# VNPay Configuration
VNP_TMNCODE=MPEBN4AM
VNP_HASHSECRET=YOUR_VNP_HASH_SECRET_HERE
VNP_API_URL=https://sandbox.vnpayment.vn/merchant_webapi/api/transaction
VNP_RETURN_URL=http://localhost:5000/api/orders/vnpay_return
VNP_IPN_URL=http://localhost:5000/api/orders/vnpay_ipn
VNP_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html

# Google API Configuration
GENNIAMA_API_KEY=YOUR_GOOGLE_API_KEY_HERE

# Google OAuth Configuration
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET_HERE
